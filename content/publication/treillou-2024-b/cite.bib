@phdthesis{Treillou2024b,
 abstract = {La zone côtière, englobant \ ̀la fois la zone de déferlement et le plateau interne, est une r\ǵion extr\m̂ement dynamique, o\`c̀oexistent et interagissent des tourbillons et des courants d'arrachement \`aìff\'éntes \'eélles. Cette interface critique entre la terre et la mer joue un r\^ê essentiel dans le transport de divers \'elémeś, tels que s\'edimt́s, contaminants (m\'etauxóurds, microplastiques, pathog\`en)̀, et traceurs biologiques comme le plancton et les larves. Ces traceurs sont li\'es \`a ́̀enjeux c\^oêrs majeurs, comme l'\'erosionés plages, la pollution littorale et la pr\'eservati ́des \'ecosyst\`ésS̀ur des plages sableuses quasi uniformes le long du littoral, les principaux m\'ecanismes  ́transport sont les courants d'arrachement transitoires, induits par des vagues multidirectionnelles. Bien que de nombreuses \'etudes aienéxplor\'e le transpo ́de traceurs passifs dans ces conditions, la plupart reposent sur des mod\`eles à vagu ̀r\'esolues bidimśionnels (Boussinesq), qui ne prennent pas en compte le cisaillement vertical, caus\'e par les court́s de surface dirig\'es vers la c\^o d̂us au d\'eferlement) et lćourant de retour vers le large pr\`es du fd̀. Cette lacune conduit \`a sous-eìmer le m\'elange dans la zo ́de d\'eferlement et \`a  ́sureìmer sur le plateau interne. R\'ecemment, des mod\`és 3D \`v̀agues r\s̀olues comme CROCO ont permis des \'etudes plus approfonés. L'objectif de cette th\`ese est d'amèliorer ces mod\`eles et d'\'el̀uer l'impact du ciíllement vertical du courant d'arrachement sur la dispersion des traceurs. La premi\`ere \'etape a ǹsist\'e \`a ŕriger un pb̀l\ḿe d'interf\'erc̀e coh\'erente dans lǵ\'en\'eraúr de vagues de CĆO,úivi de la validation de sa capacit\'e \`a reproduire les ǹamiqu ́transitoires c\^otiêres \`a l'aide d'p̀\'eric̀es en bassin \`a vagues.ńe fois lm̀od\`ele valid\'e, l'influc̀e du cisaillement ŕtical a \'et\'e examin\'ee \`a travers de ́ex'́erǹces  ́rejet de traceurs, l'unén bassin \`a vagues et l'autre lord̀'une grande campagne de terrain \`a Imperial Beach, Califoìe. Les comparaisons des simulations avec et sans cisaillement vertical ont r\'ev\'el\'e deux r\'esultats majeurs úne\́'ećtion de  ́dispersion vers le largeúe \`a l'affaiblissement de laàscade inverse de l'\'energie cin\'etique 2D, et une augmentatń du m\'elan ́dans la zone de d\'eferlement via uńouveau processus 3D, impq́uant les "mini-rips", des courants transitoires d'\'echelle interm\'ediaire r\'ecemment d\'ecouvt́s. Ce travail,úi permet  ́mieux compńdre les m\'ecanismes de transport dans les zones c\^oti\r̂,́ offre des perspectiv ̀pour am\'eliorer la param\'etrisation de mod\`eles simplif'́es.},
 author = {Treillou, Simon},
